# Private near-original mirror policy:
# Generated runtime surfaces (.codex/, .claude/, .mcp.json, CLAUDE.md)
# and explicitly approved .env files are allowed to be committed in private
# repositories. Do not print secret values in logs or reviews.

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# JavaScript/package dependencies and build outputs
node_modules/
dist/
build/
.next/
out/
coverage/

# Virtual environments and local dependency folders
.venv/
venv/
env/

# Rebuildable local caches
runtime/session-recall.sqlite

# OS
.DS_Store
Thumbs.db
