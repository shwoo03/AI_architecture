{
  "schema_version": "ai-architecture.schema.v1",
  "name": "completion-evidence",
  "type": "object",
  "required": [
    "ts",
    "goal",
    "changed_paths",
    "validations",
    "outcome"
  ],
  "properties": {
    "ts": {"type": "string"},
    "goal": {"type": "string"},
    "changed_paths": {"type": "array", "items": {"type": "string"}},
    "validations": {"type": "array", "items": {"type": "object"}},
    "outcome": {"type": "string", "enum": ["genuine_success", "partial_progress", "timeout", "infra_error", "blocked_by_policy"]},
    "disposition": {"type": "string", "enum": ["complete", "partial", "blocked", "deferred", "failed"]},
    "residual_risk": {"type": "string"},
    "next_action": {"type": "string"},
    "notes": {"type": "string"},
    "agent": {"type": "string"},
    "artifacts": {"type": "array", "items": {"type": "string"}}
  }
}
